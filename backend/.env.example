# Weather Kitchen Backend - Environment Variables Template
# Copy this to .env and configure for your environment

# Application
APP_NAME="Weather Kitchen API"
APP_VERSION="0.1.0"
DEBUG=false
ENVIRONMENT="development"

# Database
# For SQLite (development):
DATABASE_URL="sqlite:///./weather_kitchen.db"
# For PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@localhost/weather_kitchen"
DATABASE_ECHO=false

# CORS - Allowed origins for frontend requests
CORS_ORIGINS='["http://localhost:5173","http://localhost:3000"]'
CORS_CREDENTIALS=true
CORS_METHODS='["GET","POST","PUT","DELETE","OPTIONS","PATCH"]'
CORS_HEADERS='["*"]'

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GENERAL=10
RATE_LIMIT_PIN_REQUESTS=5
RATE_LIMIT_PIN_WINDOW_MINUTES=15

# Logging
LOG_LEVEL="INFO"

# Authentication & Authorization
PIN_MIN_LENGTH=4
PIN_MAX_LENGTH=6
PIN_MAX_ATTEMPTS=5
PIN_LOCKOUT_MINUTES=15
BCRYPT_ROUNDS=12

# JWT Authentication — REQUIRED in production
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY="CHANGE-ME-generate-with-secrets.token_hex(32)"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Pagination
PAGINATION_DEFAULT_LIMIT=20
PAGINATION_MAX_LIMIT=100

# Request Validation
REQUEST_BODY_SIZE_LIMIT_KB=100
